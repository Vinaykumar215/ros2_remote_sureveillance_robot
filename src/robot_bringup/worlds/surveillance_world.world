<?xml version="1.0"?>
<sdf version="1.6">
  <world name="surveillance_facility">

    <!-- ==================== PHYSICS ==================== -->
    <physics type="ode">
      <real_time_update_rate>1000</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
    </physics>

    <!-- ==================== LIGHTING ==================== -->

    <!-- Ambient base light (dim, like indoor fluorescent) -->
    <ambient>0.3 0.3 0.3 1</ambient>
    <background>0.1 0.1 0.1 1</background>

    <!-- Main overhead light - Entry hall -->
    <light name="ceiling_light_entry" type="point">
      <pose>0 0 4.5 0 0 0</pose>
      <diffuse>0.9 0.9 0.85 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>12</range>
        <constant>0.4</constant>
        <linear>0.1</linear>
        <quadratic>0.01</quadratic>
      </attenuation>
      <cast_shadows>true</cast_shadows>
    </light>

    <!-- Corridor light -->
    <light name="ceiling_light_corridor" type="point">
      <pose>0 10 4.5 0 0 0</pose>
      <diffuse>0.85 0.85 0.8 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>10</range>
        <constant>0.4</constant>
        <linear>0.1</linear>
        <quadratic>0.02</quadratic>
      </attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <!-- Control room light -->
    <light name="ceiling_light_control" type="point">
      <pose>10 10 4.5 0 0 0</pose>
      <diffuse>0.8 0.85 0.9 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>10</range>
        <constant>0.4</constant>
        <linear>0.1</linear>
        <quadratic>0.02</quadratic>
      </attenuation>
      <cast_shadows>true</cast_shadows>
    </light>

    <!-- Storage room light (dimmer, like a back room) -->
    <light name="ceiling_light_storage" type="point">
      <pose>-10 10 4.5 0 0 0</pose>
      <diffuse>0.6 0.6 0.55 1</diffuse>
      <specular>0.05 0.05 0.05 1</specular>
      <attenuation>
        <range>8</range>
        <constant>0.5</constant>
        <linear>0.15</linear>
        <quadratic>0.02</quadratic>
      </attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <!-- Emergency red light near exit -->
    <light name="emergency_light" type="point">
      <pose>8 -4 3 0 0 0</pose>
      <diffuse>0.9 0.1 0.1 1</diffuse>
      <specular>0.1 0.0 0.0 1</specular>
      <attenuation>
        <range>4</range>
        <constant>0.6</constant>
        <linear>0.2</linear>
        <quadratic>0.05</quadratic>
      </attenuation>
      <cast_shadows>false</cast_shadows>
    </light>


    <!-- ==================== GROUND FLOOR ==================== -->
    <model name="floor">
      <static>true</static>
      <link name="link">
        <collision name="col">
          <geometry><plane><normal>0 0 1</normal><size>40 40</size></plane></geometry>
        </collision>
        <visual name="vis">
          <geometry><plane><normal>0 0 1</normal><size>40 40</size></plane></geometry>
          <material>
            <ambient>0.45 0.42 0.38 1</ambient>
            <diffuse>0.55 0.52 0.48 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>


    <!-- ==================== OUTER PERIMETER WALLS ==================== -->

    <!-- South wall (bottom boundary) -->
    <model name="outer_wall_south">
      <static>true</static>
      <pose>0 -8 2.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>32 0.3 5</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>32 0.3 5</size></box></geometry>
          <material><ambient>0.75 0.73 0.70 1</ambient><diffuse>0.80 0.78 0.75 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- North wall (top boundary) -->
    <model name="outer_wall_north">
      <static>true</static>
      <pose>0 18 2.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>32 0.3 5</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>32 0.3 5</size></box></geometry>
          <material><ambient>0.75 0.73 0.70 1</ambient><diffuse>0.80 0.78 0.75 1</diffuse></material>
