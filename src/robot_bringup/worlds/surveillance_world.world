        <visual name="vis">
          <geometry><box><size>0.3 26 5</size></box></geometry>
          <material><ambient>0.75 0.73 0.70 1</ambient><diffuse>0.80 0.78 0.75 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- East wall (right boundary) -->
    <model name="outer_wall_east">
      <static>true</static>
      <pose>16 5 2.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.3 26 5</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.3 26 5</size></box></geometry>
          <material><ambient>0.75 0.73 0.70 1</ambient><diffuse>0.80 0.78 0.75 1</diffuse></material>
        </visual>
      </link>
    </model>


